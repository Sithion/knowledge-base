# PostgreSQL
POSTGRES_USER=knowledge
POSTGRES_PASSWORD=knowledge_secret
POSTGRES_DB=knowledge_base
POSTGRES_PORT=5433

# Ollama
OLLAMA_MODEL=all-minilm
EMBEDDING_DIMENSIONS=384
OLLAMA_PORT=11435

# Dashboard
DASHBOARD_PORT=3847

# --- Host connections (MCP server, CLI) ---
DATABASE_URL=postgresql://knowledge:knowledge_secret@localhost:5433/knowledge_base
OLLAMA_HOST=http://localhost:11435

# --- Internal Docker network (used by dashboard container automatically) ---
# DATABASE_URL_INTERNAL=postgresql://knowledge:knowledge_secret@kb-postgres:5432/knowledge_base
# OLLAMA_HOST_INTERNAL=http://kb-ollama:11434
