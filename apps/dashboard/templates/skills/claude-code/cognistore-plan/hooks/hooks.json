{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_SKILL_DIR}/hooks/pre-plan-file-check.sh",
            "timeout": 5
          }
        ],
        "matcher": "Write|Edit|MultiEdit|NotebookEdit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_SKILL_DIR}/hooks/pre-enter-plan-check.sh",
            "timeout": 5
          }
        ],
        "matcher": "EnterPlanMode"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_SKILL_DIR}/hooks/pre-create-plan-check.sh",
            "timeout": 5
          }
        ],
        "matcher": "mcp__cognistore__createPlan"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_SKILL_DIR}/hooks/pre-exit-plan-check.sh",
            "timeout": 5
          }
        ],
        "matcher": "ExitPlanMode"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_SKILL_DIR}/hooks/post-plan-check.sh",
            "timeout": 5
          }
        ],
        "matcher": "ExitPlanMode"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_SKILL_DIR}/hooks/post-create-plan-marker.sh",
            "timeout": 5
          }
        ],
        "matcher": "mcp__cognistore__createPlan"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_SKILL_DIR}/hooks/post-edit-task-sync.sh",
            "timeout": 5
          }
        ],
        "matcher": "Edit|Write|MultiEdit|Bash|NotebookEdit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_SKILL_DIR}/hooks/post-task-update-marker.sh",
            "timeout": 5
          }
        ],
        "matcher": "mcp__cognistore__updatePlanTask|mcp__cognistore__updatePlanTasks"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_SKILL_DIR}/hooks/post-update-plan-cleanup.sh",
            "timeout": 5
          }
        ],
        "matcher": "mcp__cognistore__updatePlan"
      }
    ]
  }
}
