{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_SKILL_DIR}/hooks/pre-plan-file-check.sh",
            "timeout": 5
          }
        ],
        "matcher": "Write|Edit|MultiEdit|NotebookEdit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_SKILL_DIR}/hooks/pre-enter-plan-check.sh",
            "timeout": 5
          }
        ],
        "matcher": "EnterPlanMode"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_SKILL_DIR}/hooks/pre-create-plan-check.sh",
            "timeout": 5
          }
        ],
        "matcher": "mcp__cognistore__createPlan"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_SKILL_DIR}/hooks/post-plan-check.sh",
            "timeout": 5
          }
        ],
        "matcher": "ExitPlanMode"
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_SKILL_DIR}/hooks/subagent-stop-reconcile.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_SKILL_DIR}/hooks/post-compact-reinject.sh"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_SKILL_DIR}/hooks/task-completed-check.sh"
          }
        ]
      }
    ]
  }
}