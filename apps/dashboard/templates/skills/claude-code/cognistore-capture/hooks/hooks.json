{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_SKILL_DIR}/hooks/stop-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_SKILL_DIR}/hooks/post-add-knowledge-marker.sh",
            "timeout": 5
          }
        ],
        "matcher": "mcp__cognistore__addKnowledge"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_SKILL_DIR}/hooks/post-capture-nudge.sh",
            "timeout": 5
          }
        ],
        "matcher": "Edit|Write|MultiEdit|Bash|NotebookEdit"
      }
    ]
  }
}
