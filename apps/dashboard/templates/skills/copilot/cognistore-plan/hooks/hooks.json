{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "bash": "${COPILOT_SKILL_DIR}/hooks/pre-plan-file-check.sh",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "${COPILOT_SKILL_DIR}/hooks/pre-enter-plan-check.sh",
        "timeoutSec": 5
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "${COPILOT_SKILL_DIR}/hooks/post-plan-check.sh",
        "timeoutSec": 5
      }
    ],
    "subagentStop": [
      {
        "type": "bash",
        "bash": "${COPILOT_SKILL_DIR}/hooks/subagent-stop-reconcile.sh",
        "timeoutSec": 10
      }
    ],
    "postCompact": [
      {
        "type": "bash",
        "bash": "${COPILOT_SKILL_DIR}/hooks/post-compact-reinject.sh",
        "timeoutSec": 10
      }
    ],
    "taskCompleted": [
      {
        "type": "bash",
        "bash": "${COPILOT_SKILL_DIR}/hooks/task-completed-check.sh",
        "timeoutSec": 10
      }
    ]
  }
}
