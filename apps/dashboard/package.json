{
  "name": "@ai-knowledge/dashboard",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && tsc -p server/tsconfig.json",
    "dev": "vite",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-server",
    "test": "if find . -name '*.test.ts' -o -name '*.spec.ts' | grep -q .; then npx playwright test; else echo 'No tests found, skipping'; fi",
    "server": "tsx server/index.ts",
    "server:build": "tsc -p server/tsconfig.json",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:bundle": "node scripts/bundle-sidecar.mjs && tauri build"
  },
  "dependencies": {
    "@ai-knowledge/config": "workspace:*",
    "@ai-knowledge/core": "workspace:*",
    "@ai-knowledge/sdk": "workspace:*",
    "@ai-knowledge/shared": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "@tanstack/react-query": "^5.0.0",
    "fastify": "^5.8.2",
    "i18next": "^25.8.18",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.13.1",
    "recharts": "^2.15.0",
    "tsx": "^4.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
