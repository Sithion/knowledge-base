{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-v2-capabilities/refs/heads/main/capabilities.schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "remote": {
    "urls": ["http://localhost:*"]
  },
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "updater:default",
    "process:default"
  ]
}
