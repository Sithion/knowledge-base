{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "AI Knowledge Base",
  "identifier": "com.ai-knowledge.dashboard",
  "version": "../package.json",
  "build": {
    "frontendDist": "./splash"
  },
  "app": {
    "windows": [
      {
        "title": "AI Knowledge Base",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* http://127.0.0.1:*; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../sidecar-bundle/dist": "dist",
      "../sidecar-bundle/dist-server": "dist-server",
      "../sidecar-bundle/node_modules": "node_modules",
      "../templates": "templates"
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
