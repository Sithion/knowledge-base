{
  "name": "@cognistore/sdk",
  "version": "0.9.9",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "if find . -name '*.test.ts' -o -name '*.spec.ts' | grep -q .; then npx playwright test; else echo 'No tests found, skipping'; fi"
  },
  "dependencies": {
    "@cognistore/core": "workspace:*",
    "@cognistore/embeddings": "workspace:*",
    "@cognistore/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@playwright/test": "^1.50.0"
  }
}
